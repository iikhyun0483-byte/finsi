# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# FRED API (무료 - https://fred.stlouisfed.org/docs/api/api_key.html)
FRED_API_KEY=your_fred_api_key

# Gemini API (뉴스 감성 분석용)
GEMINI_API_KEY=your_gemini_api_key

# Financial Modeling Prep API (펀더멘털 데이터용 - Optional)
FMP_API_KEY=your_fmp_api_key

# News API (뉴스 수집용 - Optional)
NEWS_API_KEY=your_news_api_key

# API Keys (Optional - 자동매매 활성화 시 필요)
TRADING_API_KEY=
TRADING_API_SECRET=
